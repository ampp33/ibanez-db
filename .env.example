# ===========================================
# Ibanez DB - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.

# --- Database (Supabase / Postgres) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/ibanez_db

# --- MinIO / S3 Object Storage ---
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ibanez-images
# Set to "s3" to use AWS S3 instead of MinIO
STORAGE_PROVIDER=minio
# Only needed when using AWS S3:
# STORAGE_REGION=us-east-1

# --- Backend Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3001
NODE_ENV=development

# --- Frontend ---
NUXT_PUBLIC_API_BASE=http://localhost:3001
NUXT_PUBLIC_STORAGE_BASE=http://localhost:9000/ibanez-images

# --- Scraper ---
SCRAPE_CONCURRENCY=5
SCRAPE_DELAY_MS=500
