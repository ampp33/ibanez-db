{
  "name": "@ibanez-db/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "scrape": "tsx src/jobs/scrape-guitars.ts",
    "migration:create": "mikro-orm migration:create",
    "migration:up": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "schema:update": "mikro-orm schema:update --run",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@ibanez-db/shared": "*",
    "@mikro-orm/cli": "^6.4.0",
    "@mikro-orm/core": "^6.4.0",
    "@mikro-orm/migrations": "^6.4.0",
    "@mikro-orm/postgresql": "^6.4.0",
    "@types/nodemailer": "^7.0.11",
    "cheerio": "^1.0.0",
    "cron": "^3.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "minio": "^8.0.0",
    "nodemailer": "^8.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "undici": "^6.19.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  }
}
